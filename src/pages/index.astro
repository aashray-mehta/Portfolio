---
import Header from '../components/Header.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { projects } from '../data/projects'
import '../styles/global.css'

const site = Astro.site?.href ?? 'https://aashraymehta.com'
const canonical = new URL(Astro.url.pathname, site).href
const title = 'Aashray Mehta'
const description = 'Portfolio of Aashray Mehta — Solutions Architect building AI tools, apps, and internet experiments.'
const image = new URL('/og.png', site).href

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Aashray Mehta',
  url: site,
    description: 'Solutions Architect building AI tools and apps that probably didn’t need to exist but now do.',
  sameAs: [
    'https://github.com/aashray-mehta',
    'https://www.linkedin.com/in/aashray-mehta',
  ],
}

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: title,
  url: site,
  description,
  author: {
    '@type': 'Person',
    name: 'Aashray Mehta',
    url: site,
  },
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
  </head>
  <body>
    <main class="mx-auto max-w-2xl px-6 pb-20 pt-20">
      <Header />

      <section class="mb-12">
        <h2 class="mb-3 font-mono text-sm font-semibold uppercase tracking-widest text-neutral-500">
          About
        </h2>
        <p class="text-neutral-400">
          I’m Aashray. I spend most of my time fixing systems, breaking them slightly, and then rebuilding them better. By day I’m a Solutions Architect at Blue Frog. By night (and weekends), I build random tools and apps that probably didn’t need to exist but now do. This is my corner of the internet where those experiments live.
        </p>
      </section>

      <section>
        <h2 class="mb-6 font-mono text-sm font-semibold uppercase tracking-widest text-neutral-500">
          Projects
        </h2>
        <div class="grid gap-4">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    </main>

    <footer class="fixed bottom-0 left-0 right-0 z-50 border-t border-neutral-800/50 bg-[#0a0a0a]/60 backdrop-blur-md">
      <div class="mx-auto flex max-w-2xl items-center justify-between px-6 py-3">
        <p class="text-xs text-neutral-600">
          &copy; {new Date().getFullYear()} Aashray Mehta
        </p>
        <button
          id="open-idea-modal"
          type="button"
          class="text-xs text-neutral-500 transition-colors hover:text-neutral-300"
        >
          Submit an Idea &rarr;
        </button>
      </div>
    </footer>

    <dialog
      id="idea-modal"
      class="m-auto w-full max-w-md rounded-lg border border-neutral-800 bg-neutral-900 p-0 text-neutral-300 shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm"
    >
      <div class="p-6">
        <div class="mb-5 flex items-center justify-between">
          <h3 class="font-mono text-sm font-semibold uppercase tracking-widest text-neutral-400">
            Submit an Idea
          </h3>
          <button
            id="close-idea-modal"
            type="button"
            class="text-neutral-600 transition-colors hover:text-neutral-300"
            aria-label="Close"
          >
            &#x2715;
          </button>
        </div>

        <form id="idea-form" class="space-y-4">
          <input type="hidden" name="access_key" value="bf4d24d7-89e7-4b0a-a480-12505ce98400" />
          <input type="hidden" name="subject" value="New Idea Submission — aashraymehta.com" />
          <input type="hidden" name="from_name" value="Portfolio Idea Form" />

          <div>
            <label for="idea-name" class="mb-1 block text-xs text-neutral-500">Name</label>
            <input
              id="idea-name"
              name="name"
              type="text"
              required
              class="w-full rounded border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-200 placeholder-neutral-600 outline-none transition-colors focus:border-neutral-500"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="idea-email" class="mb-1 block text-xs text-neutral-500">Email</label>
            <input
              id="idea-email"
              name="email"
              type="email"
              required
              class="w-full rounded border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-200 placeholder-neutral-600 outline-none transition-colors focus:border-neutral-500"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="idea-description" class="mb-1 block text-xs text-neutral-500">The Idea</label>
            <textarea
              id="idea-description"
              name="idea"
              required
              rows="6"
              class="w-full resize-none rounded border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-200 placeholder-neutral-600 outline-none transition-colors focus:border-neutral-500"
              placeholder="Describe your half-baked idea..."
            ></textarea>
          </div>

          <div class="flex items-start gap-2">
            <input
              id="idea-certified"
              name="certified"
              type="checkbox"
              required
              class="mt-1 h-3.5 w-3.5 shrink-0 cursor-pointer appearance-none rounded-sm border border-neutral-600 bg-neutral-800 checked:border-neutral-500 checked:bg-neutral-600"
            />
            <label for="idea-certified" class="cursor-pointer text-xs leading-relaxed text-neutral-500">
              I certify that this half-baked idea that I'm not gonna build is mine, and I'm 100%
              giving it to Aashray for nothing but a name shoutout if it is built.
            </label>
          </div>

          <button
            type="submit"
            class="w-full rounded bg-neutral-700 px-4 py-2 text-sm font-medium text-neutral-200 transition-colors hover:bg-neutral-600 disabled:cursor-not-allowed disabled:opacity-50"
          >
            Send It
          </button>
        </form>

        <div id="idea-success" class="hidden py-8 text-center">
          <p class="mb-1 text-sm text-neutral-300">Idea received.</p>
          <p class="text-xs text-neutral-500">No take-backs.</p>
        </div>

        <div id="idea-error" class="hidden py-8 text-center">
          <p class="mb-1 text-sm text-red-400">Something went wrong.</p>
          <p class="text-xs text-neutral-500">Try again, or don't. Your call.</p>
        </div>
      </div>
    </dialog>

    <script>
      const modal = document.getElementById('idea-modal') as HTMLDialogElement;
      const form = document.getElementById('idea-form') as HTMLFormElement;
      const successEl = document.getElementById('idea-success')!;
      const errorEl = document.getElementById('idea-error')!;

      document.getElementById('open-idea-modal')!.addEventListener('click', () => {
        form.classList.remove('hidden');
        successEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        form.reset();
        modal.showModal();
      });

      document.getElementById('close-idea-modal')!.addEventListener('click', () => {
        modal.close();
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Sending...';

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form))),
          });

          if (res.ok) {
            form.classList.add('hidden');
            successEl.classList.remove('hidden');
          } else {
            throw new Error('Submission failed');
          }
        } catch {
          form.classList.add('hidden');
          errorEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send It';
        }
      });
    </script>
  </body>
</html>
