---
import Header from '../components/Header.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { projects } from '../data/projects'
import '../styles/global.css'

const site = Astro.site?.href ?? 'https://aashraymehta.com'
const canonical = new URL(Astro.url.pathname, site).href
const title = 'Aashray Mehta — Public Registry'
const description = 'Public registry of small software incidents. Access granted for review purposes only.'
const image = new URL('/og.png', site).href

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Aashray Mehta',
  url: site,
  description:
    'Independent developer maintaining a public registry of software records, prototypes, and incidents. Some entries are withheld.',
  sameAs: ['https://github.com/aashray-mehta', 'https://www.linkedin.com/in/aashray-mehta'],
}

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: title,
  url: site,
  description,
  author: {
    '@type': 'Person',
    name: 'Aashray Mehta',
    url: site,
  },
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

    <style>
      .idea-checkbox:checked {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 4L5.5 9.5L3 7' stroke='%23e8e4dc' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
      }
    </style>
  </head>

  <body>
    <main class="mx-auto max-w-2xl px-6 pb-20 pt-20">
      <div class="animate-in">
        <Header />
      </div>

      <section class="mb-14 animate-in" style="animation-delay: 75ms">
        <h2 class="mb-3 text-[10px] font-semibold uppercase tracking-[0.25em] text-lab-text-muted">
          Disclosure
        </h2>
        <div class="space-y-3 text-xs leading-relaxed text-lab-text-secondary">
          <p>This site is a public registry of small software records.</p>
          <p>Most entries began as “this would be easy” and ended as “now it exists.”</p>
          <p>Nothing here is a product. Some records are active. Others are retained for historical reasons.</p>
          <p class="text-lab-text-muted">Operator: Aashray Mehta. Liability: declined.</p>
        </div>
      </section>

      <section class="animate-in" style="animation-delay: 125ms">
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="text-[10px] font-semibold uppercase tracking-[0.25em] text-lab-text-muted">
            Public Registry
          </h2>
          <span class="text-[10px] text-lab-text-muted">{projects.length} records on file</span>
        </div>

        <div class="divide-y divide-lab-border">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))}
        </div>
      </section>
    </main>

    <footer class="fixed bottom-0 left-0 right-0 z-50 border-t border-lab-border bg-lab-bg/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-2xl items-center justify-between px-6 py-3">
        <p class="text-[10px] uppercase tracking-wider text-lab-text-muted">
          Notice: Records may be incomplete. &copy; {new Date().getFullYear()} Aashray Mehta
        </p>
        <button
          id="open-idea-modal"
          type="button"
          class="text-[10px] uppercase tracking-wider text-lab-text-muted transition-colors hover:text-lab-text"
        >
          [Open Intake]
        </button>
      </div>
    </footer>

    <div
      id="idea-overlay"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm"
    >
      <div
        id="idea-modal"
        class="relative z-[101] w-full max-w-md border border-lab-border bg-lab-surface p-0 text-lab-text shadow-2xl"
      >
        <div class="p-6">
          <div class="mb-5 flex items-center justify-between">
            <h3 class="text-[10px] font-semibold uppercase tracking-[0.25em] text-lab-text-muted">
              Intake
            </h3>
            <button
              id="close-idea-modal"
              type="button"
              class="text-lab-text-muted transition-colors hover:text-lab-text"
              aria-label="Close"
            >
              &#x2715;
            </button>
          </div>

          <form id="idea-form" class="space-y-4">
            <input type="hidden" name="access_key" value="bf4d24d7-89e7-4b0a-a480-12505ce98400" />
            <input type="hidden" name="subject" value="[INTAKE] New request recorded — aashraymehta.com" />
            <input type="hidden" name="from_name" value="Intake System" />

            <div>
              <label for="idea-name" class="mb-1 block text-[10px] uppercase tracking-wider text-lab-text-muted">
                Name
              </label>
              <input
                id="idea-name"
                name="name"
                type="text"
                required
                class="w-full border border-lab-border bg-lab-bg px-3 py-2 text-xs text-lab-text placeholder-lab-text-muted outline-none transition-colors focus:border-lab-border-light"
                placeholder="Required for attribution disputes"
              />
            </div>

            <div>
              <label for="idea-email" class="mb-1 block text-[10px] uppercase tracking-wider text-lab-text-muted">
                Email
              </label>
              <input
                id="idea-email"
                name="email"
                type="email"
                required
                class="w-full border border-lab-border bg-lab-bg px-3 py-2 text-xs text-lab-text placeholder-lab-text-muted outline-none transition-colors focus:border-lab-border-light"
                placeholder="Required for non-response"
              />
            </div>

            <div>
              <label for="idea-description" class="mb-1 block text-[10px] uppercase tracking-wider text-lab-text-muted">
                Request
              </label>
              <textarea
                id="idea-description"
                name="idea"
                required
                rows="6"
                class="w-full resize-none border border-lab-border bg-lab-bg px-3 py-2 text-xs text-lab-text placeholder-lab-text-muted outline-none transition-colors focus:border-lab-border-light"
                placeholder="Describe the request. Provide just enough detail to regret it."
              ></textarea>
            </div>

            <div class="flex items-start gap-2">
              <input
                id="idea-certified"
                name="certified"
                type="checkbox"
                required
                class="idea-checkbox mt-0.5 h-3.5 w-3.5 shrink-0 cursor-pointer appearance-none border border-lab-border bg-lab-bg checked:border-lab-text-muted checked:bg-lab-text-muted"
              />
              <label for="idea-certified" class="cursor-pointer text-[10px] leading-relaxed text-lab-text-muted">
                I confirm this request is mine (or mine enough). I am voluntarily submitting it for potential development.
                Credit may be granted. Compensation will not.
              </label>
            </div>

            <div class="h-captcha" data-captcha="true" data-theme="dark"></div>

            <button
              type="submit"
              class="w-full border border-lab-border bg-lab-bg px-4 py-2 text-xs text-lab-text-secondary transition-colors hover:border-lab-border-light hover:text-lab-text disabled:cursor-not-allowed disabled:opacity-50"
            >
              Transmit
            </button>
          </form>

          <div id="idea-success" class="hidden py-8 text-center">
            <p class="mb-1 text-xs text-lab-text">Intake recorded.</p>
            <p class="text-[10px] text-lab-text-muted">No reversals.</p>
          </div>

          <div id="idea-error" class="hidden py-8 text-center">
            <p class="mb-1 text-xs text-status-closed">Transmission failed.</p>
            <p class="text-[10px] text-lab-text-muted">Retry optional. Outcome unchanged.</p>
          </div>
        </div>
      </div>
    </div>

    <script>
      const overlay = document.getElementById('idea-overlay')!;
      const modal = document.getElementById('idea-modal')!;
      const form = document.getElementById('idea-form') as HTMLFormElement;
      const successEl = document.getElementById('idea-success')!;
      const errorEl = document.getElementById('idea-error')!;

      function openModal() {
        form.classList.remove('hidden');
        successEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        form.reset();
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        document.body.style.overflow = '';
      }

      document.getElementById('open-idea-modal')!.addEventListener('click', openModal);
      document.getElementById('close-idea-modal')!.addEventListener('click', closeModal);

      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !overlay.classList.contains('hidden')) closeModal();
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const hCaptcha = form.querySelector<HTMLTextAreaElement>('textarea[name=h-captcha-response]');
        if (!hCaptcha || !hCaptcha.value) {
          alert('Verification required to transmit intake.');
          return;
        }

        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Transmitting...';

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form))),
          });

          if (res.ok) {
            form.classList.add('hidden');
            successEl.classList.remove('hidden');
          } else {
            throw new Error('Submission failed');
          }
        } catch {
          form.classList.add('hidden');
          errorEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Transmit';
        }
      });
    </script>

    <script src="https://web3forms.com/client/script.js" async defer></script>
  </body>
</html>