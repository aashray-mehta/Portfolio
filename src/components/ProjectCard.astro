---
import type { Project } from '../data/projects'

interface Props {
  project: Project
  index: number
}

const { project, index } = Astro.props

const isRedacted = project.status === 'upcoming' || project.status === 'closed'

const isClickable = project.status === 'live' && project.url
const Tag = isClickable ? 'a' : 'div'

const statusLabel: Record<Project['status'], string> = {
  live: '[OPERATIONAL]',
  upcoming: '[CLASSIFIED]',
  closed: '[DECOMMISSIONED]',
}

const statusColor: Record<Project['status'], string> = {
  live: 'text-status-live',
  upcoming: 'text-lab-text-muted',
  closed: 'text-status-closed',
}

const delay = 200 + index * 75
---

<Tag
  {...(isClickable ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' } : {})}
  class:list={[
    'group block py-5 animate-in transition-colors',
    project.status === 'live' && 'hover:bg-lab-surface/50',
    (project.status === 'upcoming' || project.status === 'closed') && 'cursor-default',
  ]}
  style={`animation-delay: ${delay}ms`}
>
  <div class="flex items-baseline justify-between gap-4">
    <div class="flex items-baseline gap-3">
      <span class="text-[10px] uppercase tracking-wider text-lab-text-muted">{project.id}</span>
      <h3 class:list={[
        'text-sm font-semibold',
        isRedacted ? 'text-lab-text-muted select-none' : 'text-lab-text group-hover:text-lab-text-secondary',
      ]}>
        {isRedacted ? '██████ ████████' : project.name}
      </h3>
    </div>
    <span class={`shrink-0 text-[10px] uppercase tracking-wider ${statusColor[project.status]}`}>
      {statusLabel[project.status]}
    </span>
  </div>

  <p class:list={[
    'mt-1.5 text-xs leading-relaxed',
    isRedacted ? 'text-lab-text-muted select-none' : 'text-lab-text-secondary',
  ]}>
    {isRedacted
      ? 'Record withheld. Submit an intake request for reconsideration.'
      : project.description}
  </p>

  <div class="mt-2 text-[10px] text-lab-text-muted">
    {isRedacted
      ? 'TAGS: REDACTED / ACCESS: RESTRICTED'
      : project.tags.join(' / ')}
  </div>
</Tag>