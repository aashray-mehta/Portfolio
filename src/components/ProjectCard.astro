---
import type { Project } from '../data/projects'

interface Props {
  project: Project
}

const { project } = Astro.props

const statusColor: Record<Project['status'], string> = {
  live: 'bg-green-500',
  upcoming: 'bg-yellow-500',
  closed: 'bg-red-500',
}

const isRedacted = project.status === 'upcoming' || project.status === 'closed'
const Tag = project.url ? 'a' : 'div'
---

<Tag
  {...(project.url ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' } : {})}
  class:list={[
    'group block rounded-lg border p-5 transition-colors',
    project.status === 'live' && 'border-neutral-800 hover:border-neutral-600 hover:bg-neutral-900/50',
    project.status === 'upcoming' && 'border-dashed border-neutral-800/40 opacity-60 cursor-default',
    project.status === 'closed' && 'border-neutral-800/30 opacity-40 cursor-default line-through decoration-neutral-700',
  ]}
>
  <div class="flex items-center gap-2">
    <span class={`inline-block h-2 w-2 shrink-0 rounded-full ${statusColor[project.status]}`}></span>
    <h3 class:list={[
      'font-mono text-lg font-semibold',
      isRedacted ? 'text-neutral-700 select-none' : 'text-white group-hover:text-neutral-200',
    ]}>
      {isRedacted ? '██████ ████████' : project.name}
    </h3>
  </div>
  <p class:list={['mt-2 text-sm', isRedacted ? 'text-neutral-700 select-none' : 'text-neutral-400']}>
    {isRedacted ? '██████ ████ ██ ████ ███████ ████ ███ ████ ██ ███.' : project.description}
  </p>
  <div class="mt-3 flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span class:list={[
        'rounded-full px-2.5 py-0.5 text-xs',
        isRedacted ? 'bg-neutral-800/50 text-neutral-700 select-none' : 'bg-neutral-800 text-neutral-300',
      ]}>
        {isRedacted ? '████' : tag}
      </span>
    ))}
  </div>
</Tag>
